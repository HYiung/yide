{
  "version": 2,
  "builds": [
    {
      "src": "yide/yide/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.10"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "yide/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "yide/yide/wsgi.py"
    }
  ]
}