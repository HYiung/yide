{
  "version": 2,
  "builds": [
    {
      "src": "yide/yide/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "yide/yide/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "settings" 
  }
}