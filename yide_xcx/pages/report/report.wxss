page {
  background: #f6f6f6;
}

.container {
  padding: 24rpx;
}

.header {
  font-size: 40rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 24rpx;
}

.range-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.range-tabs button {
  background: #ffffff;
  color: #07c160;
  border: 2rpx solid #07c160;
}

.range-tabs button.active {
  background: #07c160;
  color: #ffffff;
}

.summary-card,
.section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 26rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.summary-card {
  display: flex;
  flex-direction: column;
}

.date-range {
  color: #888;
  font-size: 24rpx;
}

.amount {
  color: #07c160;
  font-size: 58rpx;
  font-weight: 900;
  margin: 12rpx 0;
}

.count {
  color: #333;
  font-size: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.rank-row,
.record-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-top: 1rpx solid #f0f0f0;
  color: #333;
  font-size: 28rpx;
}

.record-row > view {
  display: flex;
  flex-direction: column;
}

.record-name {
  font-weight: 600;
}

.record-date {
  color: #999;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.empty {
  color: #999;
  text-align: center;
  padding: 40rpx 0;
}
