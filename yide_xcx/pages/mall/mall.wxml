<scroll-view class="mall-container" scroll-y="true" bindscrolltolower="onLoadMore">

  <!-- 👤 店主浏览模式提示 -->
  <view class="admin-banner" wx:if="{{isAdmin}}">
    <text>👤 店主浏览模式 · 仅可查看</text>
  </view>

  <!-- 🔍 搜索栏 -->
  <view class="search-bar">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input placeholder="搜索商品名称…" bindinput="onSearchInput" bindconfirm="doSearch" value="{{searchKey}}" confirm-type="search" placeholder-class="search-placeholder" />
      <text wx:if="{{searchKey}}" class="search-clear" bindtap="clearSearch">✕</text>
    </view>
  </view>

  <!-- 📂 分类导航栏 -->
  <scroll-view class="category-bar" scroll-x="true" show-scrollbar="{{false}}">
    <view class="cat-item {{activeCat == item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id"
      bindtap="switchCat" data-id="{{item.id}}">{{item.name}}</view>
  </scroll-view>

  <!-- 📦 商品列表 -->
  <view wx:if="{{loading}}" class="loading-tip">加载中...</view>

  <view class="product-grid" wx:elif="{{products.length > 0}}">
    <view class="product-card" wx:for="{{products}}" wx:key="id">
      <!-- 商品图片 -->
      <view class="card-img-wrap" style="background:{{item.categoryColor}};">
        <text class="card-emoji">{{item.productEmoji}}</text>
        <!-- 新品/库存标签 -->
        <view class="card-badge hot" wx:if="{{isNewProduct(item)}}">新品</view>
        <view class="card-badge low" wx:elif="{{item.stock <= 5}}">仅剩{{item.stock}}</view>
      </view>
      <!-- 商品信息 -->
      <view class="card-info">
        <text class="card-name">{{item.name}}</text>
        <view class="card-meta">
          <text class="card-price">￥{{item.price}}</text>
          <text class="card-stock" wx:if="{{item.stock > 10}}">库存充足</text>
          <text class="card-stock warn" wx:elif="{{item.stock <= 5}}">仅剩{{item.stock}}</text>
          <text class="card-stock" wx:else>剩{{item.stock}}</text>
        </view>
        <!-- 操作按钮 -->
        <button wx:if="{{!isAdmin}}" class="btn-add" size="mini" bindtap="addToCart" data-item="{{item}}">加入购物车</button>
        <view wx:else class="admin-only-tag">🔒 仅顾客购买</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!loading && products.length == 0}}" class="empty-tip">
    <text class="empty-icon">📭</text>
    <text>该分类暂无商品</text>
  </view>

  <view style="height: 160rpx;"></view>
</scroll-view>

<!-- 🛒 购物车遮罩 -->
<view class="cart-mask" wx:if="{{showCartDetail && !isAdmin}}" bindtap="toggleCartDetail"></view>

<!-- 🛒 购物车详情弹窗 -->
<view class="cart-detail {{showCartDetail ? 'show' : ''}}" wx:if="{{!isAdmin}}">
  <view class="cart-header">
    <text>已选商品</text>
    <view class="clear-btn" bindtap="clearCart">
      <text>🗑️ 清空</text>
    </view>
  </view>
  <scroll-view scroll-y="true" class="cart-list">
    <view class="cart-item" wx:for="{{cart}}" wx:key="id">
      <view class="cart-item-left">
        <text class="cart-item-name">{{item.name}}</text>
        <text class="cart-item-price">￥{{item.price}}</text>
      </view>
      <view class="quantity-ctrl">
        <view class="qty-btn" bindtap="minusItem" data-id="{{item.id}}">−</view>
        <text class="qty-num">{{item.num}}</text>
        <view class="qty-btn" bindtap="plusItem" data-id="{{item.id}}">+</view>
      </view>
    </view>
  </scroll-view>
</view>

<!-- 🛒 底部结算栏 -->
<view class="cart-bar {{showCartDetail ? 'bar-up' : ''}}" wx:if="{{totalCount > 0 && !isAdmin}}">
  <view class="cart-info" bindtap="toggleCartDetail">
    <view class="cart-icon-wrap">
      <text class="cart-emoji">🛒</text>
      <text class="badge">{{totalCount > 99 ? '99+' : totalCount}}</text>
    </view>
    <view class="cart-price-wrap">
      <text class="total-text">合计</text>
      <text class="price-num">￥{{totalPrice}}</text>
    </view>
    <text class="arrow">{{showCartDetail ? '▼' : '▲'}}</text>
  </view>
  <view class="settle-btn" bindtap="goToOrder">去结算</view>
</view>