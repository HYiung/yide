.category-bar {
  white-space: nowrap;
  /* 核心：不换行才能横向滚动 */
  background: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  /* 粘性定位：滚动时固定在顶部 */
  top: 0;
  z-index: 100;
}

.cat-item {
  display: inline-block;
  padding: 10rpx 30rpx;
  margin: 0 10rpx;
  font-size: 28rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
  color: #666;
}

.cat-item.active {
  background: #07c160;
  color: #fff;
  font-weight: bold;
}

/* 底部悬浮条 */
.cart-bar {
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  height: 100rpx;
  background: #333;
  border-radius: 50rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 10rpx 0 40rpx;
  z-index: 999;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.2);
}

.cart-info {
  display: flex;
  align-items: center;
}

.cart-icon {
  position: relative;
  margin-right: 20rpx;
}

.badge {
  position: absolute;
  top: -15rpx;
  right: -15rpx;
  background: #ff4d4f;
  color: white;
  font-size: 20rpx;
  padding: 0 10rpx;
  border-radius: 20rpx;
  border: 2rpx solid #333;
}

.total-text {
  color: white;
  font-size: 28rpx;
}

.price {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.settle-btn {
  background: #07c160;
  color: white;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 40rpx;
  border-radius: 40rpx;
  font-weight: bold;
  font-size: 30rpx;
}

/* 遮罩 */
.cart-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 990;
}

/* 弹出清单主体 */
.cart-detail {
  position: fixed;
  left: 0;
  right: 0;
  bottom: -800rpx;
  /* 初始隐藏在屏幕下方 */
  background: white;
  z-index: 991;
  border-radius: 30rpx 30rpx 0 0;
  transition: all 0.3s ease;
  /* 动画过渡 */
  max-height: 700rpx;
  padding-bottom: 140rpx;
}

.cart-detail.show {
  bottom: 0;
}

/* 弹出时的位置 */

.cart-header {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  background: #f8f8f8;
  border-radius: 30rpx 30rpx 0 0;
}

.clear-btn {
  color: #999;
  font-size: 26rpx;
}

.cart-list {
  max-height: 500rpx;
}

.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.item-right {
  display: flex;
  align-items: center;
}

.quantity-ctrl {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.quantity-ctrl .btn {
  width: 44rpx;
  height: 44rpx;
  border: 1rpx solid #ddd;
  text-align: center;
  line-height: 40rpx;
  border-radius: 50%;
  margin: 0 15rpx;
}