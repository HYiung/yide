/* ====================================
   一得书苑 · 线上商城
   参考主流电商小程序设计语言
   ==================================== */

page {
  background: #f5f5f5;
}

.mall-container {
  min-height: 100vh;
  padding: 0;
  box-sizing: border-box;
}

/* ========== 店主浏览提示 ========== */
.admin-banner {
  background: #fff3cd;
  color: #856404;
  font-size: 24rpx;
  text-align: center;
  padding: 12rpx 0;
  line-height: 1.5;
}

/* ========== 搜索栏 ========== */
.search-bar {
  background: #fff;
  padding: 16rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 200;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 0 24rpx;
  height: 72rpx;
  transition: all 0.2s;
}

.search-box:focus-within {
  background: #fff;
  box-shadow: 0 0 0 2rpx #07c160;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-box input {
  flex: 1;
  font-size: 28rpx;
  height: 72rpx;
  color: #333;
  background: transparent;
}

.search-placeholder {
  color: #bbb;
  font-size: 26rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
  margin-left: 8rpx;
}

/* ========== 分类导航 ========== */
.category-bar {
  white-space: nowrap;
  background: #fff;
  padding: 16rpx 20rpx 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.cat-item {
  display: inline-block;
  padding: 12rpx 30rpx;
  margin: 0 8rpx;
  font-size: 30rpx;
  border-radius: 34rpx;
  background: #f5f5f5;
  color: #666;
  transition: all 0.2s;
}

.cat-item.active {
  background: #07c160;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.25);
}

/* ========== 商品网格 ========== */
.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 20rpx 20rpx 0;
}

.product-card {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  transition: transform 0.2s, box-shadow 0.2s;
  display: flex;
  flex-direction: column;
}

.product-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

/* 商品图片容器 */
.card-img-wrap {
  position: relative;
  width: 100%;
  padding-top: 80%;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.card-img-wrap image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 角标 - 新品/热卖 */
.card-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
  color: #fff;
  z-index: 2;
}

.card-badge.hot {
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
}

.card-badge.low {
  background: linear-gradient(135deg, #fbb23b, #f0932b);
}

/* 商品信息区 */
.card-info {
  padding: 20rpx 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 1;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
  min-height: 78rpx;
}

.card-meta {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.card-price {
  font-size: 36rpx;
  font-weight: 800;
  color: #e64340;
}

.card-price::before {
  content: '¥';
  font-size: 24rpx;
  font-weight: 600;
}

.card-stock {
  font-size: 22rpx;
  color: #aaa;
}

.card-stock.warn {
  color: #ff6b6b;
}

/* 加入购物车按钮 */
.btn-add {
  margin-top: 6rpx;
  width: 100%;
  font-size: 26rpx !important;
  height: 60rpx !important;
  line-height: 60rpx !important;
  border-radius: 30rpx !important;
  background: linear-gradient(135deg, #07c160, #06ad54) !important;
  color: #fff !important;
  border: none !important;
  font-weight: 600 !important;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2) !important;
}

.btn-add::after {
  border: none !important;
}

/* 店主浏览占位 */
.admin-only-tag {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #ccc;
  background: #f9f9f9;
  border-radius: 30rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  width: 100%;
}

/* ========== 加载 & 空状态 ========== */
.loading-tip {
  text-align: center;
  padding: 120rpx 0;
  font-size: 28rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 120rpx 0;
  font-size: 28rpx;
  color: #999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
}

/* ========== 购物车遮罩 ========== */
.cart-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 990;
}

/* ========== 购物车详情弹窗 ========== */
.cart-detail {
  position: fixed;
  left: 0;
  right: 0;
  bottom: -800rpx;
  background: white;
  z-index: 991;
  border-radius: 30rpx 30rpx 0 0;
  transition: bottom 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  max-height: 700rpx;
  padding-bottom: 140rpx;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.1);
}

.cart-detail.show {
  bottom: 0;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
  background: #f8f8f8;
  border-radius: 30rpx 30rpx 0 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.clear-btn {
  color: #999;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: #eee;
}

.cart-list {
  max-height: 500rpx;
}

.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.cart-item-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.cart-item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-item-price {
  font-size: 26rpx;
  color: #e64340;
  font-weight: 600;
}

.quantity-ctrl {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  border: 2rpx solid #e0e0e0;
  text-align: center;
  line-height: 46rpx;
  border-radius: 50%;
  font-size: 30rpx;
  color: #555;
  background: #fff;
  font-weight: bold;
}

.qty-btn:active {
  background: #f0f0f0;
}

.qty-num {
  min-width: 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* ========== 底部结算栏 ========== */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(135deg, #2d2d2d, #1a1a1a);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 0 0 30rpx;
  z-index: 999;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s;
}

.cart-bar.bar-up {
  border-radius: 0;
}

.cart-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.cart-icon-wrap {
  position: relative;
  margin-right: 20rpx;
}

.cart-emoji {
  font-size: 44rpx;
}

.badge {
  position: absolute;
  top: -10rpx;
  right: -16rpx;
  background: #ff4d4f;
  color: white;
  font-size: 18rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  padding: 0 6rpx;
  border-radius: 16rpx;
  font-weight: bold;
  border: 2rpx solid #333;
}

.cart-price-wrap {
  display: flex;
  flex-direction: column;
  line-height: 1.2;
}

.total-text {
  color: #aaa;
  font-size: 22rpx;
}

.price-num {
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
}

.arrow {
  color: #888;
  font-size: 22rpx;
  margin-left: 16rpx;
}

.settle-btn {
  background: linear-gradient(135deg, #07c160, #06ad54);
  color: white;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 44rpx;
  margin-right: 20rpx;
  border-radius: 40rpx;
  font-weight: bold;
  font-size: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
  flex-shrink: 0;
}

.settle-btn:active {
  opacity: 0.85;
}