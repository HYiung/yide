<view class="container">
  <view class="today-card">
    <view class="stats-row">
      <view class="today-item">
        <text class="today-label">营收: ￥{{total_amount}}</text>
      </view>
      <view class="today-item" style="justify-content: flex-end;">
        <text class="today-label">件数: {{today_count}}</text>
      </view>
    </view>

    <view class="order-check-section">
      <view class="search-box">
        <input placeholder="输入姓名或单号后4位核销" bindinput="onSearchInput" value="{{searchKey}}"
          placeholder-style="color:#ccc;" />
        <button bindtap="searchOrder">搜索</button>
      </view>

      <view class="search-result" wx:if="{{pendingOrder}}">
        <view class="order-brief">
          <text>👤 {{pendingOrder.customer_name}}</text>
          <text>💰 ￥{{pendingOrder.total_price}}</text>
        </view>
        <view class="order-items" wx:if="{{pendingOrder.items.length > 0}}">
          <text wx:for="{{pendingOrder.items}}" wx:key="product_id">{{item.name}} × {{item.count}} </text>
        </view>
        <button class="verify-btn" type="warn" bindtap="verifyOrder" data-id="{{pendingOrder.id}}">确认取货</button>
      </view>
    </view>

    <view class="dashboard-panel" wx:if="{{pendingOrders.length > 0}}">
      <view class="panel-title">待取货订单（{{lastOrderCount}}）</view>
      <view class="pending-row" wx:for="{{pendingOrders}}" wx:key="id">
        <view class="pending-main">
          <text class="pending-name">{{item.customer_name}}</text>
          <text class="pending-sn">{{item.order_sn}}</text>
        </view>
        <button size="mini" type="warn" bindtap="verifyOrder" data-id="{{item.id}}">核销</button>
      </view>
    </view>

    <view class="dashboard-panel low-stock-panel" wx:if="{{lowStockProducts.length > 0}}">
      <view class="panel-title">低库存提醒（{{lowStockCount}}）</view>
      <view class="low-stock-row" wx:for="{{lowStockProducts}}" wx:key="id">
        <text>{{item.name}}</text>
        <text class="low-stock-num">剩 {{item.stock}}</text>
      </view>
    </view>
  </view>

  <view class="header">一得书苑 · 实时清单</view>

  <!-- 购物车列表 -->
  <view class="cart-card">
    <view wx:if="{{cart.length > 0}}">
      <view class="item-row" wx:for="{{cart}}" wx:key="id">
        <view class="item-main">
          <text class="item-name">{{item.name}}</text>
          <text class="stock-warning" wx:if="{{item.remaining_stock < 5}}">
            (库存: {{item.remaining_stock}})
          </text>
        </view>
        <view class="item-actions">
          <view class="qty-ctrl">
            <view class="qty-btn" bindtap="onDecrement" data-id="{{item.id}}">−</view>
            <text class="qty-num">{{item.quantity}}</text>
            <view class="qty-btn" bindtap="onIncrement" data-id="{{item.id}}">+</view>
          </view>
          <text class="item-price">￥{{item.price}}</text>
          <view class="del-btn" bindtap="onRemoveItem" data-id="{{item.id}}">✕</view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-tips" style="padding:100rpx 0;text-align:center;">
      <text>欢迎使用一得书苑收银系统</text>
      <text style="display:block;margin-top:20rpx;color:#999;font-size:26rpx;">扫码添加商品或选择商品后自动计入</text>
    </view>
  </view>

  <!-- 底栏：合计 + 操作按钮 -->
  <view class="footer" wx:if="{{cart.length > 0}}">
    <view class="footer-top">
      <text class="total-label">应收合计：</text>
      <text class="total-amount">￥{{total}}</text>
    </view>
    <view class="footer-actions">
      <button class="btn-clear" bindtap="onResetCart">🗑️ 清空</button>
      <button class="btn-checkout" bindtap="onFinish">✅ 收款完成</button>
    </view>
  </view>
</view>