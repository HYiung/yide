/* --- 全局背景与布局 --- */
page {
  background-color: #f5f5f5;
  padding: 0;
  box-sizing: border-box;
}

.container {
  display: flex;
  flex-direction: column;
  padding: 28rpx 10rpx 200rpx;
}

/* ========== 顶部绿色卡片 ========== */
.today-card {
  background: linear-gradient(135deg, #07c160, #06ad56);
  border-radius: 20rpx;
  padding: 20rpx 20rpx 18rpx;
  margin-bottom: 10rpx;
  box-sizing: border-box;
  width: 100%;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.2);
}

.stats-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.today-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.today-item.right {
  align-items: flex-end;
}

.today-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 2rpx;
}

.today-amount {
  font-size: 40rpx;
  font-weight: 900;
  color: #ffffff;
}

.today-badge {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.15);
  padding: 4rpx 14rpx;
  border-radius: 18rpx;
  margin-bottom: 4rpx;
}

.badge-warning {
  font-size: 20rpx;
  color: #fff;
  background: #ff4d4f;
  padding: 4rpx 12rpx;
  border-radius: 18rpx;
  display: inline-block;
}

/* 搜索核销区 */
.search-box {
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  padding: 6rpx 14rpx;
  border-radius: 36rpx;
  align-items: center;
  height: 64rpx;
  box-sizing: border-box;
}

.search-box input {
  flex: 1;
  font-size: 24rpx;
  height: 100%;
  color: #333;
  padding-left: 10rpx;
}

.search-box button {
  width: 100rpx !important;
  min-width: 100rpx !important;
  margin: 0 !important;
  padding: 0 !important;
  background: #07c160 !important;
  color: white !important;
  height: 48rpx !important;
  line-height: 48rpx !important;
  font-size: 22rpx !important;
  border-radius: 24rpx !important;
  font-weight: 600 !important;
}

.search-result {
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  background: #fffbe6;
  border: 2rpx solid #ffe58f;
  border-radius: 14rpx;
  width: 100%;
  box-sizing: border-box;
}

.order-brief {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.order-items {
  color: #666;
  font-size: 22rpx;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

/* ========== 面板标签切换 ========== */
.dashboard-section {
  background: #fff;
  border-radius: 18rpx;
  padding: 0;
  margin-bottom: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.tab-header {
  display: flex;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #888;
  font-weight: 500;
  position: relative;
  transition: all 0.2s;
  flex-wrap: nowrap;
  white-space: nowrap;
}

.tab-item > text {
  flex-shrink: 0;
}

.tab-item.active {
  color: #07c160;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
}

.tab-count {
  margin-left: 6rpx;
  background: #e8f8ee;
  color: #07c160;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 18rpx;
  font-weight: 600;
}

.tab-count.warn {
  background: #fff2f0;
  color: #ff4d4f;
}

.tab-content {
  padding: 4rpx 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.empty-tab-tip {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #ccc;
}

/* ========== 低库存样式（同时用于待取货） ========== */
.low-stock-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 10rpx;
  width: 100%;
  box-sizing: border-box;
}

.low-stock-row:last-child {
  border-bottom: none;
}

.low-stock-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.ls-emoji {
  font-size: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.ls-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.ls-stock-tag {
  background: #fff2f0;
  border: 2rpx solid #ffccc7;
  color: #ff4d4f;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 22rpx;
  flex-shrink: 0;
}

/* ========== 实时清单标题 ========== */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.section-count {
  font-size: 22rpx;
  color: #999;
  background: #f0f0f0;
  padding: 4rpx 14rpx;
  border-radius: 18rpx;
}

/* ========== 购物车卡片 ========== */
.cart-card {
  background-color: #fff;
  border-radius: 18rpx;
  padding: 4rpx 20rpx;
  min-height: 180rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.item-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.item-row:last-child {
  border-bottom: none;
}

.item-emoji {
  font-size: 32rpx;
  margin-right: 14rpx;
  width: 40rpx;
  text-align: center;
  flex-shrink: 0;
}

.item-main {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  margin-right: 10rpx;
}

.item-name-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 140rpx;
}

.stock-warning {
  font-size: 18rpx;
  color: #ff4d4f;
  background: #fff2f0;
  padding: 2rpx 8rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  font-weight: 600;
}

.item-unit-price {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 2rpx;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

/* 数量加减控件 */
.qty-ctrl {
  display: flex;
  align-items: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 6rpx;
  overflow: hidden;
}

.qty-btn {
  width: 44rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #333;
  background: #f7f7f7;
  font-weight: 600;
}

.qty-btn:active {
  background: #e8e8e8;
}

.qty-num {
  min-width: 36rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0 8rpx;
}

.item-subtotal {
  font-size: 26rpx;
  font-weight: 700;
  color: #e64340;
  min-width: 70rpx;
  text-align: right;
}

/* 删除按钮 */
.del-btn {
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  border-radius: 50%;
  background: #f5f5f5;
}

.del-btn:active {
  background: #e0e0e0;
  color: #999;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.empty-icon {
  font-size: 70rpx;
  margin-bottom: 18rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
  font-weight: 500;
}

.empty-hint {
  font-size: 22rpx;
  color: #ddd;
  margin-top: 10rpx;
}

/* ========== 底部结算区 ========== */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  background: linear-gradient(135deg, #2d2d2d, #1a1a1a);
  padding: 12rpx 18rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.footer-total {
  display: flex;
  flex-direction: column;
}

.total-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 400;
  margin-bottom: 2rpx;
}

.total-amount-row {
  display: flex;
  align-items: baseline;
}

.total-currency {
  font-size: 24rpx;
  font-weight: 700;
  color: #ffd700;
  margin-right: 2rpx;
}

.total-amount {
  font-size: 40rpx;
  font-weight: 900;
  color: #ffd700;
  line-height: 1;
}

.footer-actions {
  display: flex;
  gap: 6rpx;
  flex-shrink: 0;
}

.btn-clear {
  background: rgba(255, 255, 255, 0.10) !important;
  color: rgba(255, 255, 255, 0.6) !important;
  font-size: 22rpx !important;
  height: 44rpx !important;
  line-height: 44rpx !important;
  padding: 0 6rpx !important;
  min-width: auto !important;
  width: auto !important;
  border-radius: 22rpx !important;
  font-weight: 500 !important;
  border: 1rpx solid rgba(255, 255, 255, 0.12) !important;
  margin: 0 !important;
  display: inline-block !important;
}
.btn-clear::after {
  border: none !important;
}
.btn-clear:active {
  background: rgba(255, 255, 255, 0.18) !important;
}

.btn-checkout {
  background: linear-gradient(135deg, #07c160, #06ad56) !important;
  color: white !important;
  font-size: 22rpx !important;
  height: 44rpx !important;
  line-height: 44rpx !important;
  padding: 0 8rpx !important;
  min-width: auto !important;
  width: auto !important;
  border-radius: 22rpx !important;
  font-weight: 700 !important;
  border: none !important;
  margin: 0 !important;
  display: inline-block !important;
  box-shadow: 0 3rpx 10rpx rgba(7, 193, 96, 0.3) !important;
}
.btn-checkout::after {
  border: none !important;
}
.btn-checkout:active {
  transform: scale(0.96);
  opacity: 0.9;
}
