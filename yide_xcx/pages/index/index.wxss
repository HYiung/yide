/* --- 全局背景与布局 --- */
page {
  background-color: #f6f6f6;
  padding: 20rpx;
  box-sizing: border-box;
}

.container {
  display: flex;
  flex-direction: column;
  padding-bottom: 120rpx;
}

/* 顶部绿色卡片 */
.today-card {
  background: #07c160;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
  width: 700rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 30rpx;
}

.today-item {
  flex: 1;
  display: flex;
  align-items: center;
}

.today-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  white-space: nowrap;
}

/* 搜索核销区 */
.order-check-section {
  width: 100%;
}

.search-box {
  display: flex;
  background: #ffffff;
  padding: 10rpx 20rpx;
  border-radius: 40rpx;
  align-items: center;
  height: 80rpx;
  box-sizing: border-box;
}

.search-box input {
  flex: 1;
  font-size: 28rpx;
  height: 80rpx;
  color: #333;
}

.search-box button {
  width: 130rpx !important;
  min-width: 130rpx !important;
  margin: 0 !important;
  padding: 0 !important;
  background: #07c160 !important;
  color: white !important;
  height: 60rpx !important;
  line-height: 60rpx !important;
  font-size: 26rpx !important;
  border-radius: 30rpx !important;
}

.search-result {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #fffbe6;
  border: 2rpx solid #ffe58f;
  border-radius: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.order-brief {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.order-items {
  color: #666;
  font-size: 24rpx;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.dashboard-panel {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 16rpx;
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
}

.panel-title {
  color: #333;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.pending-row, .low-stock-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.pending-main {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.pending-name {
  color: #222;
  font-size: 28rpx;
  font-weight: 600;
}

.pending-sn {
  color: #888;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.low-stock-panel {
  border: 2rpx solid #ffd666;
}

.low-stock-num {
  color: #ff4d4f;
  font-weight: bold;
}

/* --- 实时清单标题 --- */
.header {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  padding: 20rpx 0;
  text-align: center;
}

/* --- 购物车卡片 --- */
.cart-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 10rpx 30rpx;
  min-height: 200rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-main {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.item-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.stock-warning {
  font-size: 22rpx;
  color: #ff4d4f;
  margin-top: 4rpx;
}

.item-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 数量加减控件 */
.qty-ctrl {
  display: flex;
  align-items: center;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  overflow: hidden;
}

.qty-btn {
  width: 52rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333;
  background: #f5f5f5;
}

.qty-num {
  min-width: 40rpx;
  text-align: center;
  font-size: 28rpx;
  padding: 0 8rpx;
}

.item-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #e64340;
  min-width: 80rpx;
  text-align: right;
}

/* 删除按钮 */
.del-btn {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  border-radius: 50%;
  background: #f5f5f5;
}

.empty-tips {
  color: #999;
  font-size: 32rpx;
}

/* --- 底部结算区（固定底栏） --- */
.footer {
  position: fixed;
  bottom: 0;
  left: 20rpx;
  right: 20rpx;
  background: #ffffff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #f0f0f0;
  border-radius: 20rpx 20rpx 0 0;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.footer-total {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0;
  flex-shrink: 0;
}

.total-label {
  font-size: 22rpx;
  color: #999;
  font-weight: 400;
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.total-amount {
  font-size: 40rpx;
  font-weight: 900;
  color: #e64340;
}

.footer-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.btn-clear {
  background: #f5f5f5 !important;
  color: #666 !important;
  font-size: 26rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  padding: 0 28rpx !important;
  border-radius: 32rpx !important;
  font-weight: 500 !important;
  border: none !important;
  margin: 0 !important;
}

.btn-checkout {
  background: linear-gradient(135deg, #07c160, #06ad54) !important;
  color: white !important;
  font-size: 26rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  padding: 0 36rpx !important;
  border-radius: 32rpx !important;
  font-weight: 600 !important;
  border: none !important;
  margin: 0 !important;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3) !important;
}

/* 老版清空按钮兼容（不再使用，保留以防引用） */
.clear-btn {
  margin-top: 30rpx;
  background-color: #07c160 !important;
  color: white !important;
  font-size: 38rpx !important;
  height: 100rpx !important;
  line-height: 100rpx !important;
  border-radius: 50rpx !important;
  font-weight: bold;
}

/* 老版清空按钮兼容（不再使用，保留以防引用） */
.clear-btn {
  margin-top: 30rpx;
  background-color: #07c160 !important;
  color: white !important;
  font-size: 38rpx !important;
  height: 100rpx !important;
  line-height: 100rpx !important;
  border-radius: 50rpx !important;
  font-weight: bold;
}
