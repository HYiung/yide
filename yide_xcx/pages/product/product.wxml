<view class="container">
  <!-- 双识别入口 -->
  <view class="scan-row">
    <view class="scan-section" bindtap="scanBarcode">
      <text class="scan-icon">📷</text>
      <text class="scan-text">扫码识别商品</text>
    </view>
    <view class="scan-section scan-ai" bindtap="aiRecognize">
      <text class="scan-icon">🤖</text>
      <text class="scan-text">拍照识别商品</text>
    </view>
  </view>

  <!-- AI 识别 loading -->
  <view class="ai-loading" wx:if="{{aiLoading}}">
    <view class="ai-loading-inner">
      <text class="ai-loading-icon">🤖</text>
      <text class="ai-loading-text">AI 正在识别商品...</text>
      <view class="ai-loading-bar"><view class="ai-loading-fill"></view></view>
    </view>
  </view>

  <!-- 识别图片预览 -->
  <view class="preview-row" wx:if="{{imagePreview}}">
    <image class="preview-img" src="{{imagePreview}}" mode="aspectFill" />
    <text class="preview-hint">已拍照，AI 识别结果见下方</text>
  </view>

  <view class="form-card" wx:if="{{barcode}}">
    <view class="form-row">
      <text class="flabel">条形码</text>
      <input class="finput-disabled" value="{{barcode}}" disabled />
      <text wx:if="{{currentStock !== null}}" class="stock-tip">当前库存：{{currentStock}}</text>
    </view>

    <view class="form-row">
      <text class="flabel">商品名称</text>
      <input class="finput" placeholder="请输入商品名称" model:value="{{name}}" />
    </view>

    <view class="form-row-short">
      <view class="fhalf">
        <text class="flabel">单价 (元)</text>
        <input class="finput" type="digit" placeholder="0.00" model:value="{{price}}" />
      </view>
      <view class="fhalf">
        <text class="flabel">入库数量</text>
        <input class="finput" type="number" placeholder="1" model:value="{{stock}}" />
      </view>
    </view>

    <view class="form-row">
      <text class="flabel">分类</text>
      <scroll-view class="cat-scroll" scroll-x="true" show-scrollbar="{{false}}">
        <view class="cat-option {{category == 'books' ? 'active' : ''}}" data-cat="books" bindtap="selectCategory">📚 名著书籍</view>
        <view class="cat-option {{category == 'pens' ? 'active' : ''}}" data-cat="pens" bindtap="selectCategory">🖊️ 书写工具</view>
        <view class="cat-option {{category == 'papers' ? 'active' : ''}}" data-cat="papers" bindtap="selectCategory">📓 本册纸品</view>
        <view class="cat-option {{category == 'stationery' ? 'active' : ''}}" data-cat="stationery" bindtap="selectCategory">📐 学生文具</view>
        <view class="cat-option {{category == 'correction' ? 'active' : ''}}" data-cat="correction" bindtap="selectCategory">📦 修正粘合</view>
        <view class="cat-option {{category == 'others' ? 'active' : ''}}" data-cat="others" bindtap="selectCategory">📎 其他</view>
      </scroll-view>
    </view>

    <button class="submit-btn" bindtap="submitData" loading="{{submitting}}" disabled="{{submitting}}">完成入库</button>
  </view>
</view>
<!-- 自定义底部导航 -->
<custom-tab-bar activeIndex="1" />
