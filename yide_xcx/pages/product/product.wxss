.container {
  padding: 10rpx 12rpx 140rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 双识别入口 — 并排 */
.scan-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.scan-section {
  flex: 1;
  background: #fff;
  border: 3rpx dashed #07c160;
  border-radius: 14rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.scan-section:active {
  background: #f0faf4;
}

.scan-section.scan-ai {
  border-color: #1677ff;
}

.scan-section.scan-ai:active {
  background: #e8f0fe;
}

.scan-icon {
  font-size: 30rpx;
}

.scan-text {
  font-size: 24rpx;
  color: #07c160;
  font-weight: 600;
}

.scan-ai .scan-text {
  color: #1677ff;
}

/* AI 识别 loading 动画 */
.ai-loading {
  background: #fff;
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.ai-loading-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.ai-loading-icon {
  font-size: 40rpx;
  animation: aiBounce 0.8s infinite alternate;
}

@keyframes aiBounce {
  from { transform: translateY(0); }
  to { transform: translateY(-8rpx); }
}

.ai-loading-text {
  font-size: 24rpx;
  color: #1677ff;
  font-weight: 600;
}

.ai-loading-bar {
  width: 200rpx;
  height: 6rpx;
  background: #e8f0fe;
  border-radius: 3rpx;
  overflow: hidden;
}

.ai-loading-fill {
  height: 100%;
  width: 30%;
  background: linear-gradient(90deg, #1677ff, #07c160);
  border-radius: 3rpx;
  animation: aiSlide 1.2s infinite ease-in-out;
}

@keyframes aiSlide {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(400%); }
}

/* 拍照预览 */
.preview-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #fff;
  border-radius: 14rpx;
  padding: 10rpx 14rpx;
  margin-bottom: 8rpx;
}

.preview-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  border: 2rpx solid #e8e8e8;
  flex-shrink: 0;
}

.preview-hint {
  font-size: 22rpx;
  color: #999;
  flex: 1;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 14rpx;
  padding: 12rpx 14rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.form-row {
  margin-bottom: 8rpx;
}

.form-row-short {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.fhalf {
  flex: 1;
}

.flabel {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 4rpx;
  display: block;
  font-weight: 500;
}

.finput {
  height: 56rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  background: #fff;
}

.finput-disabled {
  height: 52rpx;
  background: #f7f7f7;
  border-radius: 8rpx;
  padding: 0 12rpx;
  color: #666;
  line-height: 52rpx;
  font-size: 24rpx;
  border: 2rpx solid #eee;
}

.stock-tip {
  display: block;
  margin-top: 2rpx;
  font-size: 20rpx;
  color: #07c160;
  font-weight: 600;
}

/* 分类横向滚动 */
.cat-scroll {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  overflow-x: auto;
  padding: 4rpx 0;
}

.cat-scroll .cat-option {
  display: inline-block;
  padding: 6rpx 14rpx;
  margin-right: 8rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 22rpx;
  border: 2rpx solid transparent;
  flex-shrink: 0;
}

.cat-option:active {
  transform: scale(0.95);
}

.cat-option.active {
  background: #e8f8ee;
  color: #07c160;
  border-color: #07c160;
  font-weight: bold;
}

/* 提交按钮 */
.submit-btn {
  background: linear-gradient(135deg, #07c160, #06ad56) !important;
  color: #fff !important;
  height: 60rpx !important;
  line-height: 60rpx !important;
  border-radius: 30rpx !important;
  font-size: 26rpx !important;
  margin-top: 8rpx !important;
  font-weight: 600 !important;
  border: none !important;
  box-shadow: 0 3rpx 12rpx rgba(7, 193, 96, 0.3) !important;
}
