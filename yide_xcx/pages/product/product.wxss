.container {
  padding: 8rpx 10rpx 140rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 双识别入口 — 并排 */
.scan-row {
  display: flex;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.scan-section {
  flex: 1;
  background: #fff;
  border: 2rpx dashed #07c160;
  border-radius: 12rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.scan-section:active {
  background: #f0faf4;
}

.scan-section.scan-ai {
  border-color: #1677ff;
}

.scan-section.scan-ai:active {
  background: #e8f0fe;
}

.scan-icon {
  font-size: 26rpx;
}

.scan-text {
  font-size: 22rpx;
  color: #07c160;
  font-weight: 600;
}

.scan-ai .scan-text {
  color: #1677ff;
}

/* 扫码查询 loading */
.scan-loading {
  background: #fff;
  border-radius: 12rpx;
  padding: 18rpx;
  margin-bottom: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.scan-loading-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.scan-loading-icon {
  font-size: 36rpx;
  animation: scanPulse 1s infinite alternate;
}

@keyframes scanPulse {
  from { transform: scale(1); opacity: 0.6; }
  to { transform: scale(1.15); opacity: 1; }
}

.scan-loading-text {
  font-size: 22rpx;
  color: #07c160;
  font-weight: 600;
  text-align: center;
}

.scan-loading-bar {
  width: 200rpx;
  height: 5rpx;
  background: #e8f8ee;
  border-radius: 3rpx;
  overflow: hidden;
}

.scan-loading-fill {
  height: 100%;
  width: 30%;
  background: linear-gradient(90deg, #07c160, #06ad56);
  border-radius: 3rpx;
  animation: scanSlide 1.2s infinite ease-in-out;
}

@keyframes scanSlide {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(400%); }
}

/* 扫码查询结果状态（持久显示） */
.scan-status-bar {
  background: #f6ffed;
  border: 1px solid #b7eb8f;
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
  margin-bottom: 6rpx;
}

.scan-status-text {
  font-size: 22rpx;
  color: #389e0d;
  line-height: 1.5;
}

/* AI 识别 loading 动画 */
.ai-loading {
  background: #fff;
  border-radius: 12rpx;
  padding: 18rpx;
  margin-bottom: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.ai-loading-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.ai-loading-icon {
  font-size: 36rpx;
  animation: aiBounce 0.8s infinite alternate;
}

@keyframes aiBounce {
  from { transform: translateY(0); }
  to { transform: translateY(-8rpx); }
}

.ai-loading-text {
  font-size: 22rpx;
  color: #1677ff;
  font-weight: 600;
}

.ai-loading-bar {
  width: 160rpx;
  height: 5rpx;
  background: #e8f0fe;
  border-radius: 3rpx;
  overflow: hidden;
}

.ai-loading-fill {
  height: 100%;
  width: 30%;
  background: linear-gradient(90deg, #1677ff, #07c160);
  border-radius: 3rpx;
  animation: aiSlide 1.2s infinite ease-in-out;
}

@keyframes aiSlide {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(400%); }
}

/* AI 识别状态栏（持久显示） */
.ai-status-bar {
  background: #fffbe6;
  border: 1px solid #ffe58f;
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
  margin-bottom: 6rpx;
}

.ai-status-text {
  font-size: 22rpx;
  color: #ad8b00;
  line-height: 1.5;
}

/* 拍照预览 */
.preview-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx 10rpx;
  margin-bottom: 6rpx;
}

.preview-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 6rpx;
  border: 1px solid #e8e8e8;
  flex-shrink: 0;
}

.preview-hint {
  font-size: 20rpx;
  color: #999;
  flex: 1;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx 10rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.form-row {
  margin-bottom: 6rpx;
}

.form-row-short {
  display: flex;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.fhalf {
  flex: 1;
}

.flabel {
  font-size: 20rpx;
  color: #888;
  margin-bottom: 3rpx;
  display: block;
  font-weight: 500;
}

.finput {
  height: 44rpx;
  border: 1px solid #e8e8e8;
  border-radius: 6rpx;
  padding: 0 10rpx;
  font-size: 24rpx;
  width: 100%;
  box-sizing: border-box;
  background: #fff;
}

.finput-disabled {
  height: 38rpx;
  background: #f7f7f7;
  border-radius: 6rpx;
  padding: 0 10rpx;
  color: #666;
  line-height: 38rpx;
  font-size: 22rpx;
  border: 1px solid #eee;
}

.stock-tip {
  display: block;
  margin-top: 1rpx;
  font-size: 18rpx;
  color: #07c160;
  font-weight: 600;
}

/* 分类横向滚动 */
.cat-scroll {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  overflow-x: auto;
  padding: 2rpx 0;
}

.cat-scroll .cat-option {
  display: inline-block;
  padding: 4rpx 12rpx;
  margin-right: 6rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 20rpx;
  border: 1px solid transparent;
  flex-shrink: 0;
}

.cat-option:active {
  transform: scale(0.95);
}

.cat-option.active {
  background: #e8f8ee;
  color: #07c160;
  border-color: #07c160;
  font-weight: bold;
}

/* 提交按钮 */
.submit-btn {
  background: linear-gradient(135deg, #07c160, #06ad56) !important;
  color: #fff !important;
  height: 48rpx !important;
  line-height: 48rpx !important;
  border-radius: 24rpx !important;
  font-size: 24rpx !important;
  margin-top: 6rpx !important;
  font-weight: 600 !important;
  border: none !important;
  padding: 0 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3) !important;
}
