/* ====================================
   确认订单页
   ==================================== */

page {
  background: #f5f5f5;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ========== 头部 ========== */
.order-header {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 40rpx 0 20rpx;
}

.order-header-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.order-header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #333;
  display: block;
}

.order-header-sub {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* ========== 卡片通用 ========== */
.card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.card-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.card-count {
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
}

/* ========== 商品清单 ========== */
.product {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.product:last-of-type {
  border-bottom: none;
}

.product-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.product-unit {
  font-size: 22rpx;
  color: #bbb;
}

.product-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-shrink: 0;
}

.product-num {
  font-size: 26rpx;
  color: #888;
  min-width: 50rpx;
  text-align: center;
}

.product-total {
  font-size: 28rpx;
  color: #e64340;
  font-weight: 700;
  min-width: 80rpx;
  text-align: right;
}

.total-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  margin-top: 8rpx;
  border-top: 2rpx solid #f0f0f0;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.total-price {
  font-size: 40rpx;
  font-weight: 900;
  color: #e64340;
}

/* ========== 取货信息 ========== */
.name-input {
  border: 2rpx solid #eee;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #333;
  background: #fafafa;
  box-sizing: border-box;
  width: 100%;
}

.name-input:focus {
  border-color: #07c160;
  background: #fff;
}

.tips {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 16rpx;
  line-height: 1.5;
}

/* ========== 提交按钮 ========== */
.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #07c160, #06ad54) !important;
  color: #fff !important;
  border: none !important;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.3) !important;
  margin-top: 10rpx;
}

.submit-btn::after {
  border: none !important;
}

.submit-btn[disabled] {
  opacity: 0.6 !important;
}

/* ========== 底部说明 ========== */
.footer-note {
  text-align: center;
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #bbb;
  padding-bottom: 40rpx;
}