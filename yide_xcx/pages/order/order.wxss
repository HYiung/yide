page { background-color: #f7f7f7; }
.container { padding: 30rpx; }
.header { font-size: 36rpx; font-weight: bold; margin-bottom: 30rpx; text-align: center; }

.item-list {
  background: white; border-radius: 15rpx; padding: 30rpx; margin-bottom: 30rpx;
}
.item-title { font-weight: bold; border-bottom: 1rpx solid #eee; padding-bottom: 20rpx; margin-bottom: 20rpx; }
.product { display: flex; justify-content: space-between; margin-bottom: 20rpx; color: #666; }
.name { flex: 2; }
.num { flex: 1; text-align: center; }
.price { flex: 1; text-align: right; }
.total-line { text-align: right; border-top: 1rpx solid #eee; padding-top: 20rpx; font-weight: bold; }
.total-price { color: #ff4d4f; font-size: 36rpx; }

.input-section {
  background: white; border-radius: 15rpx; padding: 30rpx; margin-bottom: 50rpx;
}
.label { margin-bottom: 20rpx; font-weight: bold; }
.name-input { border: 1rpx solid #ddd; height: 80rpx; padding: 0 20rpx; border-radius: 8rpx; }
.tips { font-size: 24rpx; color: #999; margin-top: 15rpx; }

.submit-btn { width: 100%; height: 90rpx; border-radius: 45rpx; font-size: 32rpx; }