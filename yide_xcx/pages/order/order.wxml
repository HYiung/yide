<view class="container">
  <view class="header">确认订单</view>

  <view class="item-list">
    <view class="item-title">商品清单</view>
    <view class="product" wx:for="{{cart}}" wx:key="id">
      <text class="name">{{item.name}}</text>
      <text class="num">x{{item.num}}</text>
      <text class="price">￥{{item.price}}</text>
    </view>
    <view class="total-line">
      合计：<text class="total-price">￥{{totalPrice}}</text>
    </view>
  </view>

  <view class="input-section">
    <view class="label">取货人姓名：</view>
    <input class="name-input" placeholder="请输入您的姓名" bindinput="onNameInput" value="{{customerName}}" />
    <view class="tips">* 请务必填写真实姓名，方便柜台取货</view>
  </view>

  <button class="submit-btn" type="primary" bindtap="submitOrder" loading="{{submitting}}" disabled="{{submitting}}">提交订单</button>
</view>